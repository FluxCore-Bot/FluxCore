{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "NODE_ENV",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "passThroughEnv": [
        "DISCORD_TOKEN",
        "CLIENT_ID",
        "GUILD_ID",
        "DASHBOARD_PORT",
        "DASHBOARD_CLIENT_SECRET",
        "DASHBOARD_CALLBACK_URL",
        "DASHBOARD_SESSION_SECRET"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "DISCORD_TOKEN",
        "CLIENT_ID",
        "GUILD_ID",
        "DASHBOARD_PORT",
        "DASHBOARD_CLIENT_SECRET",
        "DASHBOARD_CALLBACK_URL",
        "DASHBOARD_SESSION_SECRET"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "deploy:commands": {
      "dependsOn": ["build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
