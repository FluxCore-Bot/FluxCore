{
  "name": "@fluxcore/dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc --build tsconfig.server.json && vite build",
    "build:server": "tsc --build tsconfig.server.json",
    "build:client": "vite build",
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.0.0",
    "@fluxcore/config": "workspace:*",
    "@fluxcore/database": "workspace:*",
    "@fluxcore/utils": "workspace:*",
    "@fluxcore/systems": "workspace:*",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-router": "^1.120.3",
    "fastify": "^5.7.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.17",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite": "^6.3.5"
  }
}
