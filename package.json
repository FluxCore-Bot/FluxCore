{
  "name": "fluxcore",
  "version": "1.0.0",
  "private": true,
  "description": "A scalable Discord bot boilerplate",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docker": "docker compose up --build",
    "start": "docker compose -f docker-compose.prod.yml up --build -d",
    "deploy:commands": "turbo run deploy:commands --filter=@fluxcore/bot",
    "db:generate": "turbo run db:generate --filter=@fluxcore/database",
    "db:migrate": "pnpm --filter @fluxcore/database db:migrate",
    "db:deploy": "pnpm --filter @fluxcore/database db:deploy",
    "db:studio": "pnpm --filter @fluxcore/database db:studio",
    "test": "turbo run test",
    "test:watch": "pnpm --filter @fluxcore/bot test:watch",
    "test:coverage": "pnpm --filter @fluxcore/bot test:coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
