    "./tempVoice/types": {
      "types": "./dist/tempVoice/types.d.ts",
      "import": "./dist/tempVoice/types.js"
    },
    "./tempVoice/persistence": {
      "types": "./dist/tempVoice/persistence.d.ts",
      "import": "./dist/tempVoice/persistence.js"
    },
    "./tempVoice/constants": {
      "types": "./dist/tempVoice/constants.d.ts",
      "import": "./dist/tempVoice/constants.js"
    },
    "./actions/config": {
      "types": "./dist/actions/config.d.ts",
      "import": "./dist/actions/config.js"
    },
    "./actions/cache": {
      "types": "./dist/actions/cache.d.ts",
      "import": "./dist/actions/cache.js"
