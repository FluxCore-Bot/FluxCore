generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TempVoiceGuildConfig {
  id           Int      @id @default(autoincrement())
  guildId      String
  hubChannelId String   @unique
  categoryId   String?
  nameTemplate String   @default("{user}'s Channel")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([guildId])
}

model TempVoiceUserSettings {
  id                Int      @id @default(autoincrement())
  guildId           String
  userId            String
  configId          Int
  channelName       String?
  userLimit         Int      @default(0)
  isLocked          Boolean  @default(false)
  isHidden          Boolean  @default(false)
  isTextClosed      Boolean  @default(false)
  bannedUserIds     String   @default("[]")
  hiddenFromUserIds String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([guildId, userId, configId])
}

model ActionRule {
  id         Int      @id @default(autoincrement())
  guildId    String
  name       String
  enabled    Boolean  @default(true)
  eventType  String
  actions    String   @default("[]")
  conditions String   @default("{}")
  priority   Int      @default(0)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([guildId, name])
  @@index([guildId, eventType])
  @@index([guildId, enabled])
}

model ActionLog {
  id         Int      @id @default(autoincrement())
  guildId    String
  ruleId     Int
  ruleName   String
  eventType  String
  actionType String
  success    Boolean
  error      String?
  metadata   String   @default("{}")
  executedAt DateTime @default(now())

  @@index([guildId, executedAt])
  @@index([ruleId])
}

model ActionGuildSettings {
  guildId       String   @id
  maxRules      Int      @default(25)
  globalEnabled Boolean  @default(true)
  logChannelId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ActionCacheInvalidation {
  id        Int      @id @default(autoincrement())
  guildId   String
  action    String // "reload" | "reloadSettings"
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Reminder {
  id        Int      @id @default(autoincrement())
  userId    String
  channelId String?
  guildId   String?
  message   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model DashboardSession {
  id                String   @id
  userId            String
  username          String
  avatar            String?
  accessToken       String
  guilds            String   @default("[]")
  guildsRefreshedAt DateTime @default(now())
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  @@index([expiresAt])
}

model MusicGuildSettings {
  guildId            String   @id
  mode               String   @default("open") // "open" | "library"
  djRoleId           String?
  defaultVolume      Int      @default(50)
  maxQueueSize       Int      @default(100)
  autoDisconnectSecs Int      @default(300)
  twentyFourSeven    Boolean  @default(false)
  lastChannelId      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MusicLibraryAlbum {
  id        Int                 @id @default(autoincrement())
  guildId   String
  name      String
  addedBy   String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  tracks    MusicLibraryTrack[]

  @@unique([guildId, name])
  @@index([guildId])
}

model MusicLibraryTrack {
  id        Int               @id @default(autoincrement())
  albumId   Int
  title     String
  sourceUrl String
  duration  Int?
  addedBy   String
  createdAt DateTime          @default(now())
  album     MusicLibraryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
}
