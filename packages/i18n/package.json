{
  "name": "@fluxcore/i18n",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./languages": {
      "types": "./dist/languages.d.ts",
      "import": "./dist/languages.js"
    },
    "./locales/*": "./src/locales/*"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/locales && cp -r src/locales dist/locales",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "translate": "tsx src/scripts/translate.ts"
  },
  "dependencies": {
    "i18next": "^25.1.3",
    "i18next-browser-languagedetector": "^8.1.0",
    "i18next-http-backend": "^3.0.2",
    "i18next-fs-backend": "^2.6.0",
    "react-i18next": "^15.5.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
