generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TempVoiceGuildConfig {
  guildId      String   @id
  hubChannelId String
  categoryId   String?
  nameTemplate String   @default("{user}'s Channel")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TempVoiceUserSettings {
  id                Int      @id @default(autoincrement())
  guildId           String
  userId            String
  channelName       String?
  userLimit         Int      @default(0)
  isLocked          Boolean  @default(false)
  isHidden          Boolean  @default(false)
  isTextClosed      Boolean  @default(false)
  bannedUserIds     String   @default("[]")
  hiddenFromUserIds String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([guildId, userId])
}
