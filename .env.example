# Copy to .env.dev for development or .env.prod for production
# IMPORTANT: Rotate all secrets regularly. Never commit .env files to git.

# === Shared (required by both bot and dashboard) ===

# Bot token from Discord Developer Portal
DISCORD_TOKEN=

# Application (client) ID from Discord Developer Portal
CLIENT_ID=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Database (PostgreSQL) - points to Docker container hostname
DATABASE_URL=postgresql://fluxcore:fluxcore@postgres:5432/fluxcore

# === Bot only ===

# (Optional) Guild ID for development - commands deploy instantly to a specific guild
GUILD_ID=

# === Cache Sync (bot ↔ dashboard) ===

# Port for the bot's internal HTTP cache sync server
BOT_SYNC_PORT=3001
# Shared secret for cache sync authentication (generate a random string)
BOT_SYNC_SECRET=
# URL the dashboard uses to reach the bot's sync server (Docker service name)
BOT_SYNC_URL=http://bot:3001

# === Dashboard only ===

# Dashboard is disabled if DASHBOARD_CLIENT_SECRET is not set
DASHBOARD_PORT=3000
DASHBOARD_CLIENT_SECRET=
DASHBOARD_CALLBACK_URL=http://localhost:3000/auth/callback
DASHBOARD_SESSION_SECRET=

# === Lavalink (Music System) ===

# Lavalink server host (Docker service name in compose, or external IP)
LAVALINK_HOST=lavalink
# Lavalink server port
LAVALINK_PORT=2333
# Lavalink server password (must match lavalink/application.yml)
LAVALINK_PASSWORD=youshallnotpass

# === Infrastructure (production only) ===

# PostgreSQL password (used by docker-compose.prod.yml)
POSTGRES_PASSWORD=

# Caddy reverse proxy domain - set to your domain for automatic TLS
DASHBOARD_DOMAIN=localhost

# Backup schedule (cron expression, default: daily at 2am)
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
